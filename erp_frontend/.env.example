# Frappe backend URL (required)
FRAPPE_URL=http://127.0.0.1:8000

# Optional: Frappe site name (auto-detected from FRAPPE_URL hostname if omitted)
# FRAPPE_SITE_NAME=site1.local

# Service account for server-side API calls (required for production)
FRAPPE_USERNAME=Administrator
FRAPPE_PASSWORD=

# Optional: API key auth (preferred over username/password in production)
# FRAPPE_API_KEY=
# FRAPPE_API_SECRET=
