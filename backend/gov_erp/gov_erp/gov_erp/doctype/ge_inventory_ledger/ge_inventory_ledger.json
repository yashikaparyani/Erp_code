{
	"name": "GE Inventory Ledger",
	"module": "Gov ERP",
	"doctype": "DocType",
	"autoname": "naming_series:",
	"engine": "InnoDB",
	"fields": [
		{
			"fieldname": "naming_series",
			"fieldtype": "Select",
			"label": "Series",
			"options": "INV-L-.#####",
			"hidden": 1
		},
		{
			"fieldname": "posting_date",
			"fieldtype": "Date",
			"label": "Posting Date",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "direction",
			"fieldtype": "Select",
			"label": "Direction",
			"options": "IN\nOUT",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "item_code",
			"fieldtype": "Link",
			"label": "Item Code",
			"options": "Item",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "item_description",
			"fieldtype": "Data",
			"label": "Item Description"
		},
		{
			"fieldname": "make",
			"fieldtype": "Data",
			"label": "Make"
		},
		{
			"fieldname": "model_no",
			"fieldtype": "Data",
			"label": "Model No."
		},
		{
			"fieldname": "hsn_code",
			"fieldtype": "Data",
			"label": "HSN Code"
		},
		{
			"fieldname": "serial_numbers",
			"fieldtype": "Small Text",
			"label": "Serial No."
		},
		{
			"fieldname": "column_break_qty",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "qty_in",
			"fieldtype": "Float",
			"label": "Qty In",
			"default": "0",
			"in_list_view": 1
		},
		{
			"fieldname": "qty_out",
			"fieldtype": "Float",
			"label": "Qty Out",
			"default": "0",
			"in_list_view": 1
		},
		{
			"fieldname": "uom",
			"fieldtype": "Data",
			"label": "UOM",
			"default": "Nos"
		},
		{
			"fieldname": "rate",
			"fieldtype": "Currency",
			"label": "Rate"
		},
		{
			"fieldname": "balance_qty",
			"fieldtype": "Float",
			"label": "Balance After",
			"read_only": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "section_break_source",
			"fieldtype": "Section Break",
			"label": "Source"
		},
		{
			"fieldname": "voucher_type",
			"fieldtype": "Data",
			"label": "Voucher Type",
			"reqd": 1
		},
		{
			"fieldname": "voucher_no",
			"fieldtype": "Dynamic Link",
			"label": "Voucher No",
			"options": "voucher_type",
			"reqd": 1
		},
		{
			"fieldname": "warehouse",
			"fieldtype": "Link",
			"label": "Warehouse",
			"options": "Warehouse"
		},
		{
			"fieldname": "column_break_source_right",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "project",
			"fieldtype": "Link",
			"label": "Project",
			"options": "Project"
		},
		{
			"fieldname": "party_name",
			"fieldtype": "Data",
			"label": "Party / Location"
		},
		{
			"fieldname": "remarks",
			"fieldtype": "Small Text",
			"label": "Remarks"
		}
	],
	"permissions": [
		{
			"role": "System Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1
		}
	],
	"sort_field": "posting_date",
	"sort_order": "DESC",
	"search_fields": "item_code,voucher_type,voucher_no,direction,project"
}
